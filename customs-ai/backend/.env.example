# Backend sozlamalari (env_prefix=CUSTOMS_). Nusxa oling: cp .env.example .env

# Tarmoq (Faza 1: faqat loopback — tashqaridan kirib bo'lmaydi)
CUSTOMS_HOST=127.0.0.1
CUSTOMS_PORT=8000

# Provayderlar: Dev 2/3/4 tayyor bo'lguncha true
CUSTOMS_USE_MOCKS=true

# GPU orchestrator (ADR-001/002). Daemon'ni backend o'zi boshqarsa true.
CUSTOMS_MANAGE_OLLAMA=false
CUSTOMS_OLLAMA_HOST=127.0.0.1
CUSTOMS_OLLAMA_PORT=11434
CUSTOMS_OLLAMA_BINARY=ollama

# Degradatsiya (§10)
CUSTOMS_STT_TIMEOUT_S=30
CUSTOMS_LLM_TIMEOUT_S=60
CUSTOMS_LLM_MAX_RETRIES=1
CUSTOMS_MIN_FREE_DISK_MB=500

# Navbat
CUSTOMS_QUEUE_MAXSIZE=100
